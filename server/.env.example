# ─── DATABASE ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/growfarm?retryWrites=true&w=majority
PORT=5000

# ─── AUTH ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here

# ─── EMAIL (Gmail App Password) ────────────────────────────────────────────────
# Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# ─── FRONTEND URL ──────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── SMS - Fast2SMS (https://www.fast2sms.com/) ────────────────────────────────
# OTPs are stored in MongoDB TTL collection — survives server restarts
FAST2SMS_API_KEY=your_fast2sms_key_here

# ─── MANDI PRICES - data.gov.in ────────────────────────────────────────────────
# Register at https://data.gov.in/ → API → Get API Key
# Without this key, the app shows sample prices as fallback
DATA_GOV_API_KEY=your_data_gov_in_api_key_here

# ─── RAZORPAY (Payment - booking deposits) ─────────────────────────────────────
# https://dashboard.razorpay.com/ → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
